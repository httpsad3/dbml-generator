# Local development environment
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=myapp_dev
DB_TYPE=mysql           # mysql | postgresql | sqlite

# Optional — defaults to ./output/
# OUTPUT_DIR=output

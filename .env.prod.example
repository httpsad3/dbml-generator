# Production environment
# Copy this file to .env.prod and fill in your values.
# DO NOT commit .env.prod to version control.

DB_HOST=db.example.com
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=strongpassword
DB_NAME=myapp_prod
DB_TYPE=postgresql      # mysql | postgresql | sqlite

# Optional — defaults to schema_prod.dbml
# OUTPUT_FILE=schema_prod.dbml
